{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pre-tool-use"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash"
    ],
    "ask": [],
    "deny": [
      "Bash(git *)",
      "Bash(jj git *)",
      "Edit(~/.claude/hooks/*)",
      "Edit(~/.claude/settings.*)",
      "Edit(.claude/hooks/*)",
      "Edit(.claude/settings.*)",
      "Read(.envrc)"
    ]
  }
}
