# vim: ft=python
import json
import sys


def main() -> None:
    input_data = json.load(sys.stdin)
    tool_name = input_data.get("tool_name", "")
    tool_input = input_data.get("tool_input", {})

    if tool_name != "Bash":
        return

    command = tool_input.get("command", "")
    tokens = command.split()
    if not tokens:
        return

    def has(*args, op=all) -> bool:
        return op([arg in tokens for arg in args])

    def blocked(what):
        return f"Blocked: {what}."

    def surprise(*args):
        something = ", ".join([f"'{arg}'" for arg in args])
        if len(args) > 1:
            something = f"one of {something}"
        return (
            "If were *trying* to commit and are thus surpised by this outcome, "
            f"perhaps you included {something} in your commit message... "
            "remove it and try again... :)"
        )

    # Steer the agent towards jj.
    if has("git"):
        print(
            blocked("use `jj` instead"),
            surprise("git"),
            file=sys.stderr,
            sep="\n",
        )
        sys.exit(2)

    if not has("jj"):
        return

    # --force is almost always the wrong choice.
    if has("--force"):
        print(
            blocked("using --force is almost certainly wrong"),
            surprise("--force"),
            file=sys.stderr,
            sep="\n",
        )
        sys.exit(2)

    # No pushes.
    if has("push"):
        print(
            blocked("pushing to a remote is not permitted"),
            surprise("push"),
            file=sys.stderr,
            sep="\n",
        )
        sys.exit(2)

    # No re-writing history.
    if has("--ignore-immutable"):
        print(
            blocked("rewriting commit history is not permitted"),
            surprise("--ignore-immutable"),
            file=sys.stderr,
            sep="\n",
        )
        sys.exit(2)

    # No funny business.
    if has("--config", "--config-file"):
        print(
            blocked("are you sure you're doing the right thing? Maybe ask for help."),
            surprise("--config", "--config-file"),
            file=sys.stderr,
            sep="\n",
        )
        sys.exit(2)

    # This one just won't work lol.
    if has("resolve"):
        print(
            blocked("`jj resolve` requires a tui that you cannot access"),
            "Read jj's output carefully -- it will tell you how to proceed "
            "(typically: use `jj new <rev>` + edit the files directly to remove conflict markers + `jj squash`).",
            surprise("resolve"),
            file=sys.stderr,
            sep="\n",
        )
        sys.exit(2)


if __name__ == "__main__":
    main()
