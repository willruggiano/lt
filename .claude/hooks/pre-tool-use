# vim: ft=python
import json
import sys


def main() -> None:
    input_data = json.load(sys.stdin)
    tool_name = input_data.get("tool_name", "")
    tool_input = input_data.get("tool_input", {})

    if tool_name != "Bash":
        return

    command = tool_input.get("command", "")
    tokens = command.split()

    # Steer the agent towards jj.
    if tokens and "git" in tokens:
        print(
            "Blocked: use `jj` instead.",
            file=sys.stderr,
        )
        sys.exit(2)

    # --force is almost always the wrong choice.
    if tokens and "jj" in tokens and "--force" in tokens:
        print("Blocked: using --force is almost certainly wrong.", file=sys.stderr)
        sys.exit(2)

    # No pushes.
    if tokens and "jj" in tokens and "push" in tokens:
        print("Blocked: pushing to a remote is not permitted.", file=sys.stderr)
        sys.exit(2)

    # No re-writing history.
    if tokens and "jj" in tokens and "--ignore-immutable" in tokens:
        print("Blocked: rewriting commit history is not permitted.", file=sys.stderr)
        sys.exit(2)

    # No sneaky maneuvers.
    if tokens and "jj" in tokens and ("--config" in tokens or "--config-file" in tokens):
        print(
            "Blocked: are you sure you're doing the right thing? Maybe ask for help.",
            file=sys.stderr,
        )
        sys.exit(2)


if __name__ == "__main__":
    main()
